<p class="question-body"><%= question.body %></p>

<%= form_with url: check_answer_question_set_path(question_set), method: :post, id: "answer-form" do |f| %>
  <%= f.hidden_field :question_id, value: question.id %>
  <%= f.text_field :answer, placeholder: "Your answer", autofocus: true, autocomplete: "off", class: "answer-input" %>
  <%= f.submit "Check", class: "btn btn-primary" %>
<% end %>
