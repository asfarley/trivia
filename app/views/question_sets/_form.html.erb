<%= form_with model: question_set do |f| %>
  <% if question_set.errors.any? %>
    <div class="errors">
      <% question_set.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title, autofocus: true %>
  </div>

  <div class="field">
    <%= f.label :description %>
    <%= f.text_area :description, rows: 3 %>
  </div>

  <div class="field">
    <%= f.label :looseness, "Answer matching" %>
    <%= f.select :looseness, QuestionSet.loosenesses.keys.map { |k| [ k.humanize.gsub("_", " "), k ] } %>
  </div>

  <div class="field">
    <%= f.label :visibility %>
    <%= f.select :visibility, QuestionSet.visibilities.keys.map { |k| [ k.capitalize, k ] } %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
