<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recall" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav>
      <a href="<%= root_path %>" class="nav-brand">Recall</a>
      <div class="nav-links">
        <% if user_signed_in? %>
          <a href="<%= question_sets_path %>">My Sets</a>
          <a href="<%= new_question_set_path %>">+ New Set</a>
          <a href="<%= destroy_user_session_path %>" data-turbo-method="delete">Sign Out</a>
        <% else %>
          <a href="<%= new_user_session_path %>">Sign In</a>
          <a href="<%= new_user_registration_path %>">Register</a>
        <% end %>
      </div>
    </nav>

    <main>
      <% if notice.present? %>
        <p class="flash flash-notice"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p class="flash flash-alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
